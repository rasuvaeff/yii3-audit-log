<?xml version="1.0"?>
<psalm
    errorLevel="1"
    findUnusedCode="false"
    resolveFromConfigFile="true"
>
    <projectFiles>
        <directory name="src"/>
        <ignoreFiles>
            <directory name="vendor"/>
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <!-- SensitiveValueMasker::mask() inherently iterates array<string, mixed> -->
        <MixedAssignment>
            <errorLevel type="suppress">
                <file name="src/SensitiveValueMasker.php"/>
            </errorLevel>
        </MixedAssignment>
    </issueHandlers>
</psalm>
